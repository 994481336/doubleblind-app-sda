            left: 12px;
            right: 48px;
            bottom: 12px;
            min-height: 28px;
            display: flex;
            align-items: center;
            padding: 0 12px;
            border-radius: 999px;
            border: 1px solid rgba(120,142,168,0.16);
            background: rgba(255,255,255,0.72);
            color: var(--muted);
            font-size: 0.68rem;
            font-weight: 620;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.82);
        }

        [data-testid="stSidebar"] div[data-testid="stFileUploader"] section:hover {
            border-color: rgba(31,103,199,0.58) !important;
            background: linear-gradient(145deg, rgba(255,255,255,0.94), rgba(221,236,255,0.68)) !important;
        }

        [data-testid="stSidebar"] div[data-testid="stFileUploader"] section button {
            border-radius: 10px !important;
            border: 1px solid rgba(31,103,199,0.22) !important;
            background: rgba(31,103,199,0.1) !important;
            color: #0f4fa8 !important;
            font-weight: 720 !important;
        }

        [data-testid="stSidebar"] div[data-testid="stFileUploader"] section p,
        [data-testid="stSidebar"] div[data-testid="stFileUploader"] section span,
        [data-testid="stSidebar"] div[data-testid="stFileUploader"] section small {
            color: transparent !important;
        }

        [data-testid="stSidebar"] div[data-testid="stFileUploader"] section button[data-testid="stBaseButton-secondary"] {
            width: 132px;
            height: 42px;
            padding: 0 !important;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center;
            background: linear-gradient(180deg, rgba(255,255,255,0.82), rgba(224,238,255,0.72)) !important;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.95), 0 8px 18px rgba(31,103,199,0.08);
        }

        [data-testid="stSidebar"] div[data-testid="stFileUploader"] section button[data-testid="stBaseButton-secondary"] > div {
            display: none !important;
        }

        [data-testid="stSidebar"] div[data-testid="stFileUploader"] section button[data-testid="stBaseButton-secondary"]::after {
            content: "选择文件";
            color: #0f4fa8;
            font-size: 0.82rem;
            font-weight: 760;
